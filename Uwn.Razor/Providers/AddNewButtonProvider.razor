@namespace Uwn.Razor.Providers
@inherits ProviderBase<AddNewButtonViewModel>

@if (Placement == Enumerations.ControlPlacement.BeforeChildContent)
{
	<AddNewButton Model="_ViewModel" />
}

<CascadingValue Value="_ViewModel" IsFixed="true">
	@ChildContent
</CascadingValue>

@if (Placement == Enumerations.ControlPlacement.AfterChildContent)
{
	<AddNewButton Model="_ViewModel" />
}

@code {
	protected override string GetDefaultId() => DefaultIds.AddNewButtonId;
}